#include <stdio.h>
#include <cstdlib> 
void update(int *a, int *b) {
    int val_a = *a;
    int val_b = *b;
    *a = val_a + val_b;
    if (val_a - val_b < 0) {
        *b = -(val_a - val_b);
    } else {
        *b = val_a - val_b;
    }
}

int main() {
    int a, b;
    int *pa = &a, *pb = &b;
    scanf("%d %d", &a, &b);
    update(pa, pb);
    printf("%d\n%d", a, b);

    return 0;
}
