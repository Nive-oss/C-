#include <iostream>
#include <vector>

using namespace std;

int main() {
    int n, q;
    cin >> n >> q;
    vector<vector<int>> outer_array(n);
    for (int i = 0; i < n; i++) {
        int k;
        cin >> k; 
        outer_array[i].resize(k);
        for (int j = 0; j < k; j++) {
            cin >> outer_array[i][j];
        }
    }
    for (int count = 0; count < q; count++) {
        int i, j;
        cin >> i >> j;
        cout << outer_array[i][j] << endl;
    }

    return 0;
}
